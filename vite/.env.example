# --- MapKit JS (Apple Maps) ---
VITE_MAPKIT_TEAM_ID=
VITE_MAPKIT_KEY_ID=
VITE_MAPKIT_MAPS_ID=
VITE_MAPKIT_ORIGIN=http://localhost:5173
# Option A: paste PEM private key (PKCS8)
VITE_MAPKIT_PRIVATE_KEY=
# Option B: provide path to .p8
VITE_MAPKIT_PRIVATE_KEY_PATH=./AuthKey_XXXXXXXXXX.p8

# --- Flight data provider (optional) ---
# VITE_FLIGHT_PROVIDER=mock | flightaware
VITE_FLIGHT_PROVIDER=mock
VITE_FLIGHTAWARE_API_KEY=
